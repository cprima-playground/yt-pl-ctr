# YouTube API credentials
# Copy this file to .env and fill in your values
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials

YT_CLIENT_ID=your-client-id.apps.googleusercontent.com
YT_CLIENT_SECRET=GOCSPX-your-client-secret
YT_PROJECT_ID=your-project-id
YT_AUTH_URI=https://accounts.google.com/o/oauth2/auth
YT_TOKEN_URI=https://oauth2.googleapis.com/token

# Refresh token - get by running:
#   uv run python scripts/get_refresh_token.py
YT_REFRESH_TOKEN=

# Local cache directory for large episode corpora (default: cache/ in project root)
# Use an external drive or large volume for multi-thousand episode caches
# YT_CACHE_DIR=/mnt/t/yt-pl-ctr

# Fetcher backend for video metadata (default: auto)
#   auto   — YouTube Data API when creds available, yt-dlp otherwise
#   api    — Force YouTube Data API (used in CI, no bot detection)
#   ytdlp  — Force yt-dlp (use on residential IP to save API quota; playlist CRUD still uses API)
# YT_FETCHER=auto

# Optional: yt-dlp cookie source (for residential runs that need auth)
# YT_COOKIES_FROM=chrome
# YT_COOKIES_FILE=/path/to/cookies.txt

# Anthropic API key — for LLM-assisted episode labeling (scripts/llm_label.py)
# Get from: https://console.anthropic.com/api-keys
# ANTHROPIC_API_KEY=sk-ant-api03-...
